{
  "name": "smartcafe-admin-client",
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "ng": "nx",
    "start": "nx serve admin",
    "build": "nx build admin",
    "watch": "nx build admin --watch --configuration development",
    "test": "nx test admin",
    "prepare": "husky",
    "lint": "nx run-many -t lint && npm run lint:styles",
    "lint:pr": "nx affected -t lint && npm run lint:styles",
    "lint:ci": "nx run-many -t lint && npm run lint:styles",
    "lint:styles": "stylelint \"**/*.scss\"",
    "lint:styles:fix": "stylelint \"**/*.scss\" --fix",
    "test:pr": "nx affected -t test",
    "test:ci": "nx run-many -t test",
    "build:pr": "nx affected -t build",
    "build:ci": "nx run-many -t build",
    "e2e": "nx e2e",
    "graph": "nx graph",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "storybook": "nx storybook shared-ui",
    "build-storybook": "nx build-storybook shared-ui",
    "test-storybook": "nx test-storybook shared-ui"
  },
  "lint-staged": {
    "*.{ts,html,scss,json,md,mjs}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ],
    "*.scss": [
      "stylelint --fix"
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
